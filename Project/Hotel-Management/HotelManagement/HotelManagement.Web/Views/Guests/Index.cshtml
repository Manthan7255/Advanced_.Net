@model IEnumerable<HotelManagement.Models.Guest>

@{
    ViewData["Title"] = "Guests";
}

<div class="card">
    <div class="card-header">
        <h2 class="card-title"><i class="fas fa-users"></i> Hotel Guests</h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="fas fa-plus"></i> Add New Guest
        </a>
    </div>

    <div class="table-container">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Address</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong><i class="fas fa-user" style="color: #60a5fa; margin-right: 8px;"></i>@item.Name</strong></td>
                        <td>@item.Email</td>
                        <td>@item.Phone</td>
                        <td>@(item.Address ?? "N/A")</td>
                        <td>
                            <div class="actions">
                                <a asp-action="Edit" asp-route-id="@item.GuestId" class="btn btn-warning btn-sm">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.GuestId" class="btn btn-danger btn-sm">
                                    <i class="fas fa-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>