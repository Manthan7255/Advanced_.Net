<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hotel Management</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>
    <nav class="navbar">
        <div class="nav-brand">
            <i class="fas fa-hotel"></i>
            <span>Hotel Management</span>
        </div>
        <div class="nav-links">
            <a asp-controller="Home" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Home" ? "active" : "")">
                <i class="fas fa-home"></i> Home
            </a>
            <a asp-controller="Rooms" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Rooms" ? "active" : "")">
                <i class="fas fa-bed"></i> Rooms
            </a>
            <a asp-controller="Guests" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Guests" ? "active" : "")">
                <i class="fas fa-users"></i> Guests
            </a>
            <a asp-controller="Bookings" asp-action="Index" class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Bookings" ? "active" : "")">
                <i class="fas fa-calendar-check"></i> Bookings
            </a>
        </div>
    </nav>

    <main class="main-content">
        @RenderBody()
    </main>

    <footer class="footer">
        <p><i class="fas fa-heart"></i> Built with ASP.NET Core | &copy; 2026 Hotel Management System</p>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>