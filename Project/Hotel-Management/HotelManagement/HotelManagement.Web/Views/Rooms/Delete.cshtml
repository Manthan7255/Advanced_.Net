@model HotelManagement.Models.Room

@{
    ViewData["Title"] = "Delete Room";
}

<div class="card" style="max-width: 500px; margin: 0 auto; text-align: center;">
    <div style="font-size: 4rem; color: #ef4444; margin-bottom: 1rem;">
        <i class="fas fa-exclamation-triangle"></i>
    </div>
    
    <h2 class="card-title" style="color: #ef4444;">Delete Room</h2>
    <p style="color: #94a3b8; margin: 1rem 0;">Are you sure you want to delete this room? This action cannot be undone.</p>

    <div style="background: rgba(239, 68, 68, 0.1); border-radius: 12px; padding: 1.5rem; margin: 1.5rem 0; text-align: left;">
        <p><strong style="color: #f87171;">Room Number:</strong> @Model.RoomNumber